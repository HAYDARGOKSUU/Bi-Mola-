<Window x:Class="BiMola.BreakWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bi'Mola Ver" Height="550" Width="450"
        Icon="logo.png"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" Loaded="Window_Loaded">
    <Window.Resources>
        <LinearGradientBrush x:Key="MainBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF1E1E2C" Offset="0.0" />
            <GradientStop Color="#FF292942" Offset="1.0" />
        </LinearGradientBrush>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="BreatheStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BreatheScale" Storyboard.TargetProperty="ScaleX">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4" Value="2.2" KeySpline="0.25,0.1 0.25,1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:7" Value="2.2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:15" Value="1" KeySpline="0.25,0.1 0.25,1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BreatheScale" Storyboard.TargetProperty="ScaleY">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4" Value="2.2" KeySpline="0.25,0.1 0.25,1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:7" Value="2.2"/>
                <SplineDoubleKeyFrame KeyTime="0:0:15" Value="1" KeySpline="0.25,0.1 0.25,1"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BreatheCircle" Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                <SplineDoubleKeyFrame KeyTime="0:0:4" Value="1.0" KeySpline="0.25,0.1 0.25,1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:7" Value="1.0"/>
                <SplineDoubleKeyFrame KeyTime="0:0:15" Value="0.3" KeySpline="0.25,0.1 0.25,1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="25" Background="{StaticResource MainBg}" BorderBrush="#FF5CDB95" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#FF5CDB95" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        <Grid Margin="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="logo.png" Width="80" Height="80" Margin="0,0,0,15">
                    <Image.Effect>
                        <DropShadowEffect Color="#FF5CDB95" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </Image.Effect>
                </Image>
                <TextBlock Text="Bi'Mola Vakti Geldi!" Foreground="#FF8EE4AF" FontSize="32" FontWeight="Black" FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF8EE4AF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Breathing Animation Container -->
                <Grid x:Name="BreatheContainer" Width="140" Height="140" Margin="0,0,0,30">
                    <Ellipse Fill="#155CDB95" Width="130" Height="130" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <Ellipse x:Name="BreatheCircle" Fill="#705CDB95" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="BreatheScale" CenterX="25" CenterY="25" ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <TextBlock x:Name="BreatheText" Text="Nefes Al..." Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
                <TextBlock x:Name="AutoSleepText" Text="60 saniye içinde uyku moduna geçilecek..." Foreground="#FFD1D1E0" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Ek Süre (15 Dk)" Height="45" Width="150" Background="#FF4B4B6A" Foreground="White" 
                            Style="{StaticResource RoundedButton}" Click="ExtraTimeButton_Click" Margin="0,0,15,0"/>
                    
                    <Button Content="Hemen Uyu" Height="45" Width="150" Background="#FF5CDB95" Foreground="#FF05386B" 
                            Style="{StaticResource RoundedButton}" Click="SleepButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
