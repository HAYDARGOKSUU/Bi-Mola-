<Window x:Class="BiMola.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bi'Mola" Height="780" Width="430"
        Icon="logo.png"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <!-- Gradient Background -->
        <LinearGradientBrush x:Key="MainBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF1E1E2C" Offset="0.0" />
            <GradientStop Color="#FF292942" Offset="1.0" />
        </LinearGradientBrush>
        <!-- Gradient Button -->
        <LinearGradientBrush x:Key="BtnBg" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF5CDB95" Offset="0.0" />
            <GradientStop Color="#FF379683" Offset="1.0" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CancelBtnBg" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFFF6B6B" Offset="0.0" />
            <GradientStop Color="#FFC94C4C" Offset="1.0" />
        </LinearGradientBrush>
        
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2A2A3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="12" Background="{TemplateBinding Background}" BorderThickness="1" BorderBrush="#FF4B4B6A">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FF05386B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FF8EE4AF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FF8EE4AF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" CornerRadius="8" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3C3C58"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFA0A0B0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Border" Width="40" Height="20" CornerRadius="10" Background="#FF2A2A3D" BorderThickness="1" BorderBrush="#FF4B4B6A" VerticalAlignment="Center">
                                <Ellipse x:Name="Knob" Width="14" Height="14" Fill="#FFA0A0B0" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF379683"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF5CDB95"/>
                                <Setter TargetName="Knob" Property="Fill" Value="White"/>
                                <Setter TargetName="Knob" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Goal Tag Button Style -->
        <Style x:Key="TagButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FFA0A0B0"/>
            <Setter Property="Background" Value="#FF2A2A3D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="12" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3C3C58"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="30" Background="{StaticResource MainBg}" BorderBrush="#FF3C3C58" BorderThickness="1" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" ShadowDepth="10" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="25,25,25,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,2,0,0">
                    <TextBlock Text="🕗" Foreground="#FF4B4B6A" FontSize="14" Margin="0,0,5,0"/>
                    <TextBlock x:Name="CurrentTimeText" Text="00:00" Foreground="#FF4B4B6A" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="logo.png" Width="36" Height="36" Margin="0,0,10,0">
                        <Image.Effect>
                            <DropShadowEffect Color="#FF5CDB95" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                        </Image.Effect>
                    </Image>
                    <TextBlock Text="Bi'Mola" Foreground="#FF8EE4AF" FontSize="32" FontWeight="Black" FontFamily="Segoe UI" VerticalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FF8EE4AF" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0">
                    <Button Content="—" Foreground="#FFA0A0B0" Background="Transparent" BorderThickness="0" 
                            FontSize="18" FontWeight="Bold" Click="MinimizeButton_Click" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="◻" Foreground="#FFA0A0B0" Background="Transparent" BorderThickness="0" 
                            FontSize="22" FontWeight="Normal" Click="MaximizeButton_Click" Cursor="Hand" Margin="0,0,10,0" Padding="0,0,0,4"/>
                    <Button Content="✕" Foreground="#FFA0A0B0" Background="Transparent" BorderThickness="0" 
                            FontSize="18" FontWeight="Bold" Click="CloseButton_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="25,20,25,20">
                
                <Grid x:Name="InputGrid" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center">
                        <!-- Gamification Stats (Level & Focus) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Border Background="#1A5CDB95" CornerRadius="12" Padding="15,8" BorderBrush="#335CDB95" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔥" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="LevelText" Text="Seviye 1" Foreground="#FFFFA500" FontSize="15" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#FFFFA500" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="|" Foreground="#FF4B4B6A" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="FocusStatsText" Text="0 Dk (Bugün)" Foreground="#FFB0B0C0" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Goal Input -->
                        <TextBlock Text="Bu oturumda neye odaklanacaksın?" Foreground="#FFA0A0B0" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Border Background="#FF1E1E2C" CornerRadius="8" BorderBrush="#FF4B4B6A" BorderThickness="1" Margin="0,0,0,10" Width="300" Height="40">
                            <TextBox x:Name="GoalInput" Background="Transparent" Foreground="White" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>

                        <!-- Goal Quick Selectors -->
                        <WrapPanel HorizontalAlignment="Center" MaxWidth="320" Margin="0,0,0,15">
                            <Button Content="📚 Ders Çalışma" Style="{StaticResource TagButton}" Click="GoalTag_Click"/>
                            <Button Content="💻 Kodlama" Style="{StaticResource TagButton}" Click="GoalTag_Click"/>
                            <Button Content="📖 Kitap Okuma" Style="{StaticResource TagButton}" Click="GoalTag_Click"/>
                            <Button Content="🎮 Oyun" Style="{StaticResource TagButton}" Click="GoalTag_Click"/>
                            <Button Content="📝 Proje / Ödev" Style="{StaticResource TagButton}" Click="GoalTag_Click"/>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Saat" Foreground="#FFA0A0B0" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox x:Name="HoursInput" Text="0" Width="70" Height="60" Style="{StaticResource RoundedTextBox}"
                                         PreviewTextInput="NumberValidationTextBox"/>
                            </StackPanel>
                            <TextBlock Text=":" Foreground="#FFA0A0B0" FontSize="30" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,15,10,0"/>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Dakika" Foreground="#FFA0A0B0" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox x:Name="MinutesInput" Text="0" Width="70" Height="60" Style="{StaticResource RoundedTextBox}"
                                         PreviewTextInput="NumberValidationTextBox"/>
                            </StackPanel>
                            <TextBlock Text=":" Foreground="#FFA0A0B0" FontSize="30" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,15,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Saniye" Foreground="#FFA0A0B0" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox x:Name="SecondsInput" Text="0" Width="70" Height="60" Style="{StaticResource RoundedTextBox}"
                                         PreviewTextInput="NumberValidationTextBox"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Quick Selectors -->
                        <TextBlock Text="Hızlı Seçim:" Foreground="#FFA0A0B0" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                            <Button Content="15 Dk" Style="{StaticResource OutlineButton}" Click="QuickSelect_Click" Tag="15"/>
                            <Button Content="30 Dk" Style="{StaticResource OutlineButton}" Click="QuickSelect_Click" Tag="30" Margin="10,0"/>
                            <Button Content="1 Saat" Style="{StaticResource OutlineButton}" Click="QuickSelect_Click" Tag="60"/>
                            <Button Content="2 Saat" Style="{StaticResource OutlineButton}" Click="QuickSelect_Click" Tag="120" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Options / Toggles -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <CheckBox x:Name="SoundToggle" Content="Gerçek Sesli Uyarı" IsChecked="True" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,20,0" Checked="SoundToggle_Checked" Unchecked="SoundToggle_Unchecked"/>
                            <CheckBox x:Name="StrictModeToggle" Content="Zorlu Mod" ToolTip="Etkinleştirilirse sayaç iptal edilemez." Style="{StaticResource ToggleSwitchStyle}" Checked="StrictModeToggle_Checked" Unchecked="StrictModeToggle_Unchecked"/>
                        </StackPanel>

                        <!-- Night Light (Blue Light Filter) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <CheckBox x:Name="NightLightToggle" Content="🌙 Gece Işığı" Style="{StaticResource ToggleSwitchStyle}" Checked="NightLightToggle_Checked" Unchecked="NightLightToggle_Unchecked" Margin="0,0,10,0" ToolTip="Uygulama içi özel mavi ışık filtresi"/>
                            <Slider x:Name="NightLightSlider" Width="70" Minimum="0" Maximum="1" Value="0.5" 
                                    LargeChange="0.1" SmallChange="0.05" IsMoveToPointEnabled="True"
                                    ValueChanged="NightLightSlider_ValueChanged" VerticalAlignment="Center" IsEnabled="False"/>
                            <TextBlock x:Name="NightLightPercentageText" Text="%50" Foreground="#FF8EE4AF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Width="28" TextAlignment="Right" Margin="2,0,10,0"/>
                            
                            <Button Content="⚙️ Win. Ayarı" Foreground="#FFB0B0C0" Background="#FF2A2A3D" BorderThickness="1" BorderBrush="#FF4B4B6A" 
                                    Padding="5,2" FontSize="11" Cursor="Hand" Click="OpenWindowsNightLight_Click" ToolTip="Windows'un kendi orijinal Gece Işığı ayarlarına git"/>
                        </StackPanel>

                        <!-- Eye Health & Limit Info Panel -->
                        <Border Background="#FF2A2A3D" CornerRadius="12" Padding="12,10" Margin="0,0,0,15" BorderBrush="#FF4B4B6A" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="💡 Göz Sağlığı &amp; Sınırlandırma" Foreground="#FF5CDB95" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock x:Name="HealthInfoText" Text="Uzun süre ekrana bakmak miyopi riskini artırır ve göz kuruluğuna yol açar. Bi'Mola ile kendinize dijital sınırlar çizin. Zorlu Mod, iradenizi güçlendirir!" Foreground="#FFF0F0F5" FontSize="12" FontWeight="Medium" TextWrapping="Wrap" LineHeight="16"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="StartButton" Content="Zamanlayıcıyı Başlat" Height="50" Background="{StaticResource BtnBg}" 
                                Style="{StaticResource RoundedButton}" Click="StartButton_Click"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="TimerGrid" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        
                        <!-- Animated Focus Status -->
                        <TextBlock Text="🎯 Odak Modu Aktif" Foreground="#FF5CDB95" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.4" Duration="0:0:1.5" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF5CDB95" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- Current Goal Display -->
                        <Border Background="#FF1E1E2C" CornerRadius="10" Padding="15" Margin="0,0,0,25" BorderBrush="#FF5CDB95" BorderThickness="1" HorizontalAlignment="Center" MinWidth="250">
                            <StackPanel>
                                <TextBlock Text="Mevcut Hedefin" Foreground="#FF808090" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="ActiveGoalText" Text="Belirtilmedi" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Kalan Süre" Foreground="#FFA0A0B0" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <Border Background="#FF2A2A3D" CornerRadius="20" Padding="20,10" HorizontalAlignment="Center" Margin="0,0,0,20" BorderBrush="#FF4B4B6A" BorderThickness="1">
                            <TextBlock x:Name="TimeLeftText" Text="01:00:00" Foreground="#FF5CDB95" FontSize="56" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FF5CDB95" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        
                        <!-- Progress Bar -->
                        <ProgressBar x:Name="TimerProgress" Height="8" Width="260" Margin="0,0,0,15" 
                                     Background="#FF2A2A3D" Foreground="#FF5CDB95" BorderThickness="0"
                                     Maximum="100" Value="100"/>

                        <!-- Expected Finish Time -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                            <TextBlock Text="Hedeflenen Bitiş Saati:" Foreground="#FF808090" FontSize="13" Margin="0,0,8,0"/>
                            <TextBlock x:Name="FinishTimeText" Text="00:00" Foreground="#FFD1D1E0" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <!-- Control Buttons -->
                        <StackPanel x:Name="ControlButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button x:Name="AddTimeButton" Content="+5 Dk" Height="45" Width="70" Background="#FF2A2A3D" Foreground="#FF5CDB95" 
                                    Style="{StaticResource RoundedButton}" Click="AddTimeButton_Click" Margin="0,0,10,0" BorderBrush="#FF5CDB95" BorderThickness="1"/>
                            
                            <Button x:Name="PauseButton" Content="Duraklat" Height="45" Width="100" Background="#FF2A2A3D" Foreground="White" 
                                    Style="{StaticResource RoundedButton}" Click="PauseButton_Click" Margin="0,0,10,0" BorderBrush="#FF4B4B6A" BorderThickness="1"/>

                            <Button x:Name="CancelButton" Content="İptal Et" Height="45" Width="90" Background="{StaticResource CancelBtnBg}" 
                                    Foreground="White" Style="{StaticResource RoundedButton}" Click="CancelButton_Click"/>
                        </StackPanel>
                        
                        <!-- Strict Mode Active Text -->
                        <TextBlock x:Name="StrictWarningText" Text="⚠️ Zorlu Mod Devrede: Kesintiye İzin Yok!" Foreground="#FFFF6B6B" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Visibility="Collapsed"/>

                        <!-- Ambient Sounds -->
                        <TextBlock Text="🎧 Odak Sesleri" Foreground="#FFA0A0B0" FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="🌧 Yağmur" Style="{StaticResource OutlineButton}" Width="85" Margin="0,0,10,0" Click="PlayRain_Click"/>
                            <Button Content="☕ Kafe" Style="{StaticResource OutlineButton}" Width="80" Margin="0,0,10,0" Click="PlayCafe_Click"/>
                            <Button Content="🔥 Şömine" Style="{StaticResource OutlineButton}" Width="85" Click="PlayFire_Click"/>
                            <Button Content="🔇 Kapat" Style="{StaticResource OutlineButton}" Width="70" Margin="10,0,0,0" Click="StopSound_Click" Foreground="#FFFF6B6B" BorderBrush="#FFFF6B6B"/>
                        </StackPanel>

                        <!-- Volume Slider -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <TextBlock Text="🔉" Foreground="#FFA0A0B0" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <Slider x:Name="VolumeSlider" Width="150" Minimum="0" Maximum="1" Value="0.5" 
                                    LargeChange="0.1" SmallChange="0.05" IsMoveToPointEnabled="True"
                                    TickFrequency="0.05" IsSnapToTickEnabled="False" 
                                    ValueChanged="VolumeSlider_ValueChanged" VerticalAlignment="Center"/>
                            <TextBlock Text="🔊" Foreground="#FFA0A0B0" FontSize="14" Margin="5,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="VolumePercentageText" Text="%50" Foreground="#FF8EE4AF" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Width="35" TextAlignment="Right"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Footer: Always Visible Tip (Grid.Row=2) -->
            <Border Grid.Row="2" Background="#FF242435" CornerRadius="0,0,30,30" Padding="15" BorderBrush="#FF3C3C58" BorderThickness="0,1,0,0">
                <TextBlock x:Name="TipText" Text="💡 İpucu: 20-20-20 Kuralı: Her 20 dakikada bir, 6m uzağa 20 saniye bakın." Foreground="#FFB0B0C0" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="350"/>
            </Border>

            <!-- Night Light Overlay -->
            <Border x:Name="NightLightOverlay" Grid.RowSpan="3" CornerRadius="30" Background="#70FF9900" Opacity="0" IsHitTestVisible="False" Visibility="Collapsed"/>

        </Grid>
    </Border>
</Window>
